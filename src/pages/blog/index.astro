---
import { format, parseISO } from "date-fns";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts } from "../../lib/posts";
import { withBase } from "../../lib/with-base";
import TagBadge from "../../components/TagBadge.astro";
import { cleanTitle } from "../../lib/clean-title";

const posts = getAllPosts();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Blog - Paul Coroneos" description="Personal blog and portfolio for Paul Coroneos.">
  {posts.length ? (
    <div class="space-y-8 py-6 md:py-10">
      <div class="space-y-2">
        <h1 class="font-display text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl md:text-5xl">
          Latest Blog Posts
        </h1>
        <p class="text-lg text-text-muted">
          Most recent post: {format(parseISO(posts[0].module.meta.date), "MMMM dd, yyyy")}
        </p>
      </div>
      <div class="space-y-4">
        {posts.map(({ link, module: { meta }, excerpt }) => (
          <article class="scroll-reveal rounded-2xl border border-border bg-surface p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-baseline xl:gap-6">
              <dl class="shrink-0">
                <dt class="sr-only">Published on</dt>
                <dd class="text-sm font-medium text-text-muted">
                  <time dateTime={meta.date}>{format(parseISO(meta.date), "MMMM dd, yyyy")}</time>
                </dd>
              </dl>
              <div class="space-y-3">
                <h2 class="font-display text-xl font-bold tracking-tight text-text-primary">
                  <a href={withBase(base, link)} transition:name={`post-title-${meta.title}`}>{cleanTitle(meta.title)}</a>
                </h2>
                <p class="text-sm text-text-muted leading-relaxed">{excerpt}</p>
                {meta.tags?.length && (
                  <ul class="flex flex-wrap gap-2">
                    {meta.tags.map((tag) => (
                      <li><TagBadge tag={tag} /></li>
                    ))}
                  </ul>
                )}
                <a
                  href={withBase(base, link)}
                  class="group inline-flex items-center text-sm font-medium text-primary transition-colors hover:text-primary-hover"
                  aria-label={`Read ${meta.title}`}
                >
                  Read more
                  <span class="ml-1 transition-transform group-hover:translate-x-0.5">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  ) : null}
</BaseLayout>
