---
import { format, parseISO } from "date-fns";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts } from "../lib/posts";

const posts = getAllPosts().filter((post) => post.module.meta.tags?.includes("leetcode"));
---

<BaseLayout title="Leetcode - Paul Coroneos" description="Leetcode solutions by Paul Coroneos">
  <div class="divide-gray-200 divide-y">
    <div class="space-y-2 py-4 md:space-y-5 md:pb-8 md:pt-6">
      <h1 class="text-gray-900 text-3xl font-extrabold leading-9 tracking-tight sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
        Latest Leetcode Solutions
      </h1>
    </div>
    <div class="flex justify-end py-4">
      <label>
        <span class="pr-2 text-lg font-medium">Search Solutions</span>
        <input
          id="leetcode-filter"
          class="appearance-none rounded border pl-2 shadow"
          type="text"
          placeholder="Type to filter titles"
        />
      </label>
    </div>
    <ul class="divide-gray-200 divide-y">
      {posts.map(({ link, module: { meta }, excerpt }) => (
        <li class="py-4 md:py-12" data-leetcode-item data-title={meta.title.toLowerCase()}>
          <article class="space-y-2 xl:grid xl:grid-cols-4 xl:items-baseline xl:space-y-0">
            <dl>
              <dt class="sr-only">Published on</dt>
              <dd class="text-gray-500 text-base font-medium leading-6">
                <time dateTime={meta.date}>{format(parseISO(meta.date), "MMMM dd, yyyy")}</time>
              </dd>
            </dl>
            <div class="space-y-5 xl:col-span-3">
              <div class="space-y-6">
                <h2 class="text-2xl font-bold leading-8 tracking-tight">
                  <a href={link} class="text-gray-900">{meta.title}</a>
                </h2>
                <div class="text-gray-500 prose">
                  <p>{excerpt}</p>
                </div>
              </div>
              <div class="text-base font-medium leading-6">
                <a href={link} class="text-secondary hover:text-primary" aria-label={`Read ${meta.title}`}>
                  Read more →
                </a>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
  <script>
    const searchInput = document.querySelector("#leetcode-filter");
    const items = Array.from(document.querySelectorAll("[data-leetcode-item]"));

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", () => {
        const value = searchInput.value.toLowerCase();
        items.forEach((item) => {
          const title = item.getAttribute("data-title") ?? "";
          item.classList.toggle("hidden", !title.includes(value));
        });
      });
    }
  </script>
</BaseLayout>
