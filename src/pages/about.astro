---
import BaseLayout from "../layouts/BaseLayout.astro";
import mdxComponents from "../lib/mdx-components";
import AboutContent, { meta } from "../../app/about/page.mdx";
---

<BaseLayout title={`${meta.title} - Paul Coroneos`} description={meta.description}>
  <article class="space-y-8 py-6 md:py-10" data-testid="blog-post">
    <header>
      <div class="space-y-1 text-center">
        <h1 class="font-display text-3xl font-extrabold tracking-tight text-text-primary sm:text-4xl md:text-5xl">
          {meta.title}
        </h1>
      </div>
    </header>
    <div class="prose px-2 py-8">
      <AboutContent components={mdxComponents} />
    </div>
  </article>
</BaseLayout>
