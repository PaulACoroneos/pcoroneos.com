---
import { withBase } from "../lib/with-base";

const base = import.meta.env.BASE_URL;
---

<header class="bg-secondary mx-auto flex max-w-3xl items-center justify-between px-1 py-2 sm:px-6 md:mt-2 md:rounded-lg md:px-4 md:py-8 xl:max-w-5xl xl:px-0">
  <a href={withBase(base, "/")} aria-label="Paul Coroneos Home" class="inline-flex items-center md:px-2">
    <img
      src={withBase(base, "/paulcoroneos.jpg")}
      alt="Paul Coroneos Profile image"
      class="h-8 w-8 rounded-full md:h-24 md:w-24"
    />
    <span class="whitespace-nowrap pl-2 text-sm text-white md:text-2xl lg:text-2xl xl:text-3xl">
      Paul Coroneos
    </span>
  </a>
  <nav class="ml-6 items-center">
    <a href={withBase(base, "/blog")} class="hover:text-primary cursor-pointer px-1 text-white transition duration-150 ease-in-out md:px-4 md:text-2xl lg:text-2xl xl:text-3xl">Blog</a>
    <a href={withBase(base, "/leetcode")} class="hover:text-primary cursor-pointer px-1 text-white transition duration-150 ease-in-out md:px-4 md:text-2xl lg:text-2xl xl:text-3xl">Leetcode</a>
    <a href={withBase(base, "/portfolio")} class="hover:text-primary cursor-pointer px-1 text-white transition duration-150 ease-in-out md:px-4 md:text-2xl lg:text-2xl xl:text-3xl">Portfolio</a>
    <a href={withBase(base, "/about")} class="hover:text-primary cursor-pointer px-1 text-white transition duration-150 ease-in-out md:px-4 md:text-2xl lg:text-2xl xl:text-3xl">About</a>
  </nav>
</header>
