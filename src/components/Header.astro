---
import { withBase } from "../lib/with-base";
import ThemeToggle from "./ThemeToggle.astro";
import MobileNav from "./MobileNav.astro";

const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-40 mx-auto flex max-w-3xl items-center justify-between bg-header px-4 py-2 backdrop-blur-md sm:px-6 md:py-4 xl:max-w-5xl">
  <a href={withBase(base, "/")} aria-label="Paul Coroneos Home" class="inline-flex items-center gap-3">
    <img
      src={withBase(base, "/paulcoroneos.jpg")}
      alt="Paul Coroneos Profile image"
      class="h-8 w-8 rounded-full md:h-16 md:w-16"
    />
    <span class="whitespace-nowrap text-sm font-display text-white md:text-xl lg:text-2xl">
      Paul Coroneos
    </span>
  </a>

  <div class="flex items-center gap-1">
    <nav class="hidden items-center md:flex" aria-label="Primary navigation">
      <a href={withBase(base, "/blog")} class="nav-link px-3 py-2 text-white transition-colors md:text-lg lg:text-xl">Blog</a>
      <a href={withBase(base, "/leetcode")} class="nav-link px-3 py-2 text-white transition-colors md:text-lg lg:text-xl">Leetcode</a>
      <a href={withBase(base, "/portfolio")} class="nav-link px-3 py-2 text-white transition-colors md:text-lg lg:text-xl">Portfolio</a>
      <a href={withBase(base, "/about")} class="nav-link px-3 py-2 text-white transition-colors md:text-lg lg:text-xl">About</a>
    </nav>
    <ThemeToggle />
    <MobileNav />
  </div>
</header>
