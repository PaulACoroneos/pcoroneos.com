---
import { withBase } from "../lib/with-base";
import TagBadge from "./TagBadge.astro";

interface Props {
  title: string;
  githubLink: string;
  deployedLink?: string;
  tags: string[];
}

const { title, githubLink, deployedLink, tags } = Astro.props;
const githubTitle = `GitHub link for ${title}`;
const deployedTitle = `Deployed link for ${title}`;
const base = import.meta.env.BASE_URL;
---

<div class="rounded-2xl border border-border bg-surface p-5 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <h2 class="font-display text-lg font-bold text-text-primary md:text-xl">{title}</h2>
    <ul class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <li><TagBadge tag={tag} /></li>
      ))}
    </ul>
    <div class="flex shrink-0 gap-2">
      <a
        class="inline-flex min-h-[44px] w-auto items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-hover"
        title={githubTitle}
        href={githubLink}
        target="_blank"
        rel="noopener noreferrer"
      >
        <img class="h-5 w-5 shrink-0" src={withBase(base, "/github.png")} alt="" />
        <span>GitHub</span>
      </a>
      {deployedLink ? (
        <a
          class="inline-flex min-h-[44px] w-auto items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-hover"
          title={deployedTitle}
          href={deployedLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          <img class="h-5 w-5 shrink-0" src={withBase(base, "/deploy.png")} alt="" />
          <span>Deploy</span>
        </a>
      ) : null}
    </div>
  </div>
</div>
