---
import { format, parseISO } from "date-fns";
import PageTitle from "../components/PageTitle.astro";
import TagBadge from "../components/TagBadge.astro";
import { withBase } from "../lib/with-base";
type PostMeta = {
  title: string;
  description?: string;
  date?: string;
  discussion?: string;
  tags?: string[];
};

interface Props {
  meta: PostMeta;
}

const { meta } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayTitle = meta.title;
---

<article class="border-t-4 border-primary" data-testid="blog-post">
  <header class="space-y-4 py-8">
    <div class="space-y-3 text-center">
      {meta.date && (
        <dl>
          <dt class="sr-only">Published on</dt>
          <dd class="text-base font-medium text-text-muted">
            <time dateTime={meta.date}>{format(parseISO(meta.date), "MMMM dd, yyyy")}</time>
          </dd>
        </dl>
      )}
      <div transition:name={`post-title-${meta.title}`}>
        <PageTitle>{displayTitle}</PageTitle>
      </div>
      {meta.tags?.length > 0 && (
        <ul class="flex flex-wrap justify-center gap-2 pt-1">
          {meta.tags.map((tag) => (
            <li><TagBadge tag={tag} /></li>
          ))}
        </ul>
      )}
    </div>
  </header>
  <div class="space-y-8">
    <div class="prose px-2 py-8">
      <slot />
    </div>
    {meta.discussion && (
      <div class="pb-16 pt-6">
        <p class="text-text">
          Want to talk about this post?
          <a href={meta.discussion} class="font-medium text-primary hover:text-primary-hover transition-colors">Discuss this on GitHub &rarr;</a>
        </p>
      </div>
    )}
  </div>
  <footer class="border-t border-border pt-8 text-sm font-medium">
    <a
      href={withBase(base, "/blog")}
      class="group inline-flex min-h-[44px] items-center text-primary transition-colors hover:text-primary-hover"
    >
      <span class="mr-1 transition-transform group-hover:-translate-x-0.5">&larr;</span>
      Back to the blog
    </a>
  </footer>
</article>
