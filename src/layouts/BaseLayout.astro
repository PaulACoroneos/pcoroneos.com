---
import Header from "../components/Header.astro";
import SectionContainer from "../components/SectionContainer.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/with-base";
import "../../css/tailwind.css";
import "../../css/night-owl.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Paul Coroneos",
  description = "A blog and portfolio by Paul Coroneos",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="apple-touch-icon" sizes="180x180" href={withBase(base, "/apple-touch-icon.png")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase(base, "/favicon-32x32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase(base, "/favicon-16x16.png")} />
    <link rel="manifest" href={withBase(base, "/site.webmanifest")} />
    <link rel="mask-icon" href={withBase(base, "/safari-pinned-tab.svg")} color="#094074" />
    <meta name="msapplication-TileColor" content="#094074" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="alternate" type="application/rss+xml" href={withBase(base, "/rss.xml")} />
  </head>
  <body>
    <Header />
    <SectionContainer>
      <main>
        <slot />
      </main>
      <Footer />
    </SectionContainer>
  </body>
</html>
